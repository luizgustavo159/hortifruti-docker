# ============ DATABASE ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=greenstore_user
DB_PASSWORD=your_secure_password_here
DB_NAME=greenstore_db
DATABASE_URL=postgres://greenstore_admin:sua_senha_segura_aqui@db:5432/greenstore_prod
DB_POOL_MAX=10
DB_POOL_IDLE_MS=10000
DB_POOL_CONN_TIMEOUT_MS=2000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ============ JWT & SECURITY ============
JWT_SECRET=substitua_por_um_segredo_muito_longo_e_seguro_min_32_chars
JWT_REFRESH_SECRET=substitua_por_outro_segredo_muito_longo_e_seguro_min_32_chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
ADMIN_BOOTSTRAP_TOKEN=token_para_criar_primeiro_admin_via_api

# ============ SERVER ============
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
METRICS_ENABLED=true
ALERT_SLOW_THRESHOLD_MS=2000

# ============ CORS ============
CORS_ORIGIN=https://yourdomain.com

# ============ REDIS (Optional) ============
REDIS_URL=redis://redis:6379

# ============ EMAIL & NOTIFICATIONS ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
RESET_EMAIL_FROM=no-reply@greenstore.local
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_URL=https://yourdomain.com/reset-password

# ============ WEBHOOKS ============
RESET_SMS_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=120

# ============ SESSION ============
SESSION_TIMEOUT_MS=3600000

# ============ IMPORTANT NOTES ============
# 1. NEVER commit actual .env file to git
# 2. Use strong passwords (min 16 chars with special chars)
# 3. Change all default secrets in production
# 4. Use environment-specific values for each deployment
# 5. Store sensitive values in a secure vault (AWS Secrets Manager, HashiCorp Vault, etc.)
