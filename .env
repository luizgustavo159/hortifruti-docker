# ============ DATABASE ============
DB_HOST=db
DB_PORT=5432
DB_USER=greenstore
DB_PASSWORD=greenstore_password
DB_NAME=greenstore
DATABASE_URL=postgres://greenstore:greenstore_password@db:5432/greenstore
DB_POOL_MAX=20
DB_POOL_IDLE_MS=10000
DB_POOL_CONN_TIMEOUT_MS=2000
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ============ JWT & SECURITY ============
# ATENÇÃO: Altere estas chaves para valores aleatórios e longos em sua máquina!
JWT_SECRET=production_access_secret_key_change_me_immediately_32chars
JWT_REFRESH_SECRET=production_refresh_secret_key_change_me_immediately_32chars
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
ADMIN_BOOTSTRAP_TOKEN=admin_token_production_2024

# ============ SERVER ============
PORT=3000
NODE_ENV=production
LOG_LEVEL=warn
METRICS_ENABLED=true
ALERT_SLOW_THRESHOLD_MS=2000

# ============ CORS ============
# Altere para o seu domínio real em produção
CORS_ORIGIN=http://localhost:3000

# ============ REDIS ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ============ EMAIL & NOTIFICATIONS ============
# Configure com seus dados reais de SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
RESET_EMAIL_FROM=
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_RESET_URL=

# ============ WEBHOOKS ============
RESET_SMS_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=120

# ============ SESSION ============
SESSION_TIMEOUT_MS=3600000

# ============ SYSTEM MODE ============
USE_IN_MEMORY_DB=false
