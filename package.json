{
  "name": "greenstore",
  "version": "1.0.0",
  "description": "GreenStore - Sistema de Controle de Estoque e Vendas para Hortifruti",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/migrate.js && node server.js",
    "migrate": "node scripts/migrate.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "test": "jest",
    "test:backend": "jest",
    "test:frontend": "npm --prefix frontend test",
    "test:all": "npm run test:backend -- --runInBand && npm run test:frontend",
    "build:frontend": "npm --prefix frontend run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^11.0.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.5",
    "pino": "^9.3.1",
    "pino-http": "^9.0.0",
    "redis": "^5.12.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "pg-mem": "^3.0.5",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/frontend/"
    ]
  }
}
